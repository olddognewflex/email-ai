# Copy to .env and fill in values. Never commit .env.

# PostgreSQL connection string
DATABASE_URL=postgresql://email_ai:email_ai_dev@localhost:5432/email_ai

# HTTP port (default: 3000)
PORT=3000

# AES-256-GCM key for encrypting stored IMAP passwords.
# Any string works; it is SHA-256 hashed internally to 32 bytes.
# Generate a strong value: openssl rand -hex 32
ENCRYPTION_KEY=change-me-before-use-generate-with-openssl-rand

# development | test | production
NODE_ENV=development
